# Ignore everything by default
*

# Except this gitignore file
!.gitignore

# Track Antigravity rules and configurations
!.gemini/
.gemini/*
!.gemini/GEMINI.md
!.gemini/progress.json
!.gemini/config/
.gemini/config/*
!.gemini/config/hooks.json

# Track Learning Dashboard
!learning/
learning/*
!learning/dashboard.html

# Track Glossary
!tutorial/
tutorial/*
!tutorial/glossary.md
